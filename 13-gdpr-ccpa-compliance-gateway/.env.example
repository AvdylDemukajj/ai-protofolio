# Database
DATABASE_URL=postgresql://gdpr_user:SecurePass123!@localhost:5432/gdpr_db

# AWS S3 Configuration (For deleting raw data)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
S3_BUCKET_NAME=user-data-backup

# Third-party Analytics (e.g., Mixpanel, Amplitude)
ANALYTICS_API_KEY=your_analytics_key

# Application
ENVIRONMENT=development
LOG_LEVEL=DEBUG