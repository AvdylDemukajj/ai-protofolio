POSTGRES_USER=sales_user
POSTGRES_DB=sales_db
DB_PASSWORD=ChangeMe_To_A_Strong_Db_Password_123!

DATABASE_URL=postgresql://sales_user:ChangeMe_To_A_Strong_Db_Password_123!@localhost:5435/sales_db

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Optional: protect API endpoints (leave empty to disable in local dev)
API_KEY=ChangeMe_To_A_Long_Random_Api_Key

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

ENVIRONMENT=development
CORS_ORIGINS=http://localhost:8502,http://localhost:8501
MAX_RESEARCH_ITERATIONS=2

# Frontend (docker maps 8502 -> 8501)
API_URL=http://localhost:8000
