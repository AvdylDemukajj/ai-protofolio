FROM python:3.9-slim

WORKDIR /app

COPY requirements.txt .
# Add streamlit to requirements for the frontend build or install separately
RUN pip install streamlit pandas plotly requests

COPY frontend/ ./frontend/
COPY backend/ ./backend/ # To share models if needed    /

EXPOSE 8501

CMD ["streamlit", "run", "frontend/app.py", "--server.address", "0.0.0.0"]