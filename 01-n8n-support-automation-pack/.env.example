# =================================================================
# SECURITY WARNING: DO NOT COMMIT REAL CREDENTIALS TO GIT
# Copy this file to .env and fill in secure values before starting.
# =================================================================

# n8n UI and encryption
N8N_ENCRYPTION_KEY=generate_a_random_32_character_string_here
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=ChangeMe_To_A_Strong_Password_123!
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678/

# Application database (shared Postgres instance with n8n metadata)
DB_PASSWORD=ChangeMe_To_A_Strong_DB_Password_456!

# Webhook authentication (sent as X-Webhook-Secret header)
WEBHOOK_SECRET=ChangeMe_To_A_Long_Random_Webhook_Secret

# Slack incoming webhook for high-priority ticket alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Used only when creating OpenAI credentials inside the n8n UI
OPENAI_API_KEY=sk-your-openai-api-key
