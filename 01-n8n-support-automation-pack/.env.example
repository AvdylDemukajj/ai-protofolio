# =================================================================
# SECURITY WARNING: DO NOT COMMIT REAL CREDENTIALS TO GITHUB
# Copy this file to .env and fill in your secure values
# =================================================================

# n8n Security
N8N_ENCRYPTION_KEY=generate_a_random_32_character_string_here_USE_IN_PROD
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=ChangeMe_To_A_Strong_Password_123!

# Database Security
DB_PASSWORD=ChangeMe_To_A_Strong_DB_Password_456!

# Webhook Configuration (Update if using a domain)
WEBHOOK_URL=http://localhost:5678